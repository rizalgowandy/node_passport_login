<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
      crossorigin="anonymous"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css"
      integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <style>
      body {
        min-height: 100vh;
        background:
          radial-gradient(circle at top left, rgba(13, 110, 253, 0.22), transparent 32rem),
          linear-gradient(135deg, #f8fbff 0%, #eef4ff 45%, #f8f9fa 100%);
      }

      .auth-shell {
        min-height: 100vh;
      }

      .auth-card {
        border: 0;
        border-radius: 1.5rem;
        box-shadow: 0 1.25rem 3rem rgba(15, 23, 42, 0.12);
      }

      .brand-icon {
        align-items: center;
        background: linear-gradient(135deg, #0d6efd, #6610f2);
        border-radius: 1.25rem;
        color: #fff;
        display: inline-flex;
        height: 4rem;
        justify-content: center;
        width: 4rem;
      }
    </style>
    <title>Node Passport Login</title>
  </head>
  <body>
    <main class="container auth-shell d-flex align-items-center py-5">
      <div class="w-100"><%- body %></div>
    </main>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
