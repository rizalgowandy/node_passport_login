<div class="row justify-content-center">
  <div class="col-lg-7">
    <div class="card auth-card">
      <div class="card-body p-4 p-md-5">
        <div class="d-flex align-items-center gap-3 mb-4">
          <div class="brand-icon flex-shrink-0">
            <i class="fa-solid fa-gauge-high fa-xl"></i>
          </div>
          <div>
            <h1 class="h3 fw-bold mb-1">Dashboard</h1>
            <p class="text-secondary mb-0">Welcome, <%= user.name %>.</p>
          </div>
        </div>

        <div class="alert alert-primary mb-4" role="alert">
          You are logged in with Passport local authentication.
        </div>

        <a href="/users/logout" class="btn btn-outline-secondary">Logout</a>
      </div>
    </div>
  </div>
</div>
